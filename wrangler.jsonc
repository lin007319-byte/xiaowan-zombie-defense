{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "xiaowan-zombie-defense-dynamic",
  "main": "./cloudflare/worker.js",
  "compatibility_date": "2026-07-18",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": true,
    "not_found_handling": "single-page-application"
  }
}
